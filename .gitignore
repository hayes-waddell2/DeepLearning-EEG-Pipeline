# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# -----------------------------------------------------------------------------
# Project data and run outputs (never commit)
# -----------------------------------------------------------------------------
data/
outputs/
runs/
local_output/
sample_data/

# Heavy data formats (defensive — should already live under data/)
*.edf
*.npy
*.h5
*.csv

# Model checkpoints
*.pt
*.pth
*.ckpt

# Logs
*.log
*.out
*.err

# Auto-generated by setuptools_scm
src/eeg_cnn_lstm/_version.py

# Local-only source files
src/visualize.py

# -----------------------------------------------------------------------------
# Plots and figures
# -----------------------------------------------------------------------------
# Block all plot outputs by default, but allow committed figures under results/.
*.png
*.jpg
*.jpeg
*.svg
*.pdf
!results/figures/*.png
!results/figures/*.jpg
!results/figures/*.svg
!results/figures/*.pdf

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

